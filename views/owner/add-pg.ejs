
<% pageCSS = 'owner-dashboard.css' %>

<section class="container owner-page mt-4">
  <h2 class="dashboard-title">Add New PG</h2>

  <nav class="owner-nav" aria-label="Owner navigation">
    <a href="/owner/dashboard">Dashboard</a>
    <a href="/owner/my-pgs">My PGs</a>
    <a class="is-active" href="/owner/add-pg">Add New PG</a>
    <a href="/owner/enquiries">Student Requests</a>
    <a href="/owner/reviews">Reviews</a>
    <a href="/chat">Chat</a>
  </nav>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="owner-alert"><%= error %></div>
  <% } %>

  <form
    action="/pg/create"
    method="POST"
    enctype="multipart/form-data"
    class="owner-form-shell"
  >
    <label>PG Title</label>
    <input type="text" name="title" required />

    <label>City</label>
    <input type="text" name="city" required />

    <label>Area</label>
    <input type="text" name="area" required />

    <label>Location (fallback)</label>
    <input type="text" name="location" placeholder="Optional, auto-filled from city + area" />

    <label>Full Address</label>
    <textarea name="fullAddress" rows="2"></textarea>

    <label>Google Maps Embed URL</label>
    <input type="text" name="mapEmbedUrl" placeholder="https://www.google.com/maps/embed?..." />

    <label>Monthly Rent</label>
    <input type="number" name="rent" required />

    <label>Rent Breakdown</label>
    <input type="text" name="rentBreakdown" placeholder="Rent + food + electricity details" />

    <label>Total Beds</label>
    <input type="number" name="totalBeds" min="1" value="1" required />

    <label>Available Beds</label>
    <input type="number" name="availableBeds" min="0" value="1" required />

    <label>Owner Contact Number</label>
    <input type="text" name="ownerContact" placeholder="Shown only after request approval" />

    <label>Room Type</label>
    <select name="roomType" required>
      <option value="single">Single</option>
      <option value="shared">Shared</option>
    </select>

    <label>Gender Preference</label>
    <select name="genderPreference">
      <option value="any">Any</option>
      <option value="boys">Boys</option>
      <option value="girls">Girls</option>
    </select>

    <label>Facilities (comma separated)</label>
    <input type="text" name="facilities" placeholder="WiFi, Food, Laundry" />

    <label>Rules</label>
    <textarea name="rules"></textarea>

    <label>Upload Photos</label>
    <input type="file" name="images" multiple />

    <button type="submit" class="btn btn-primary mt-3">
      Create PG
    </button>
  </form>
</section>