
<% pageCSS = 'owner-dashboard.css' %>

<section class="container owner-page mt-4">
  <h2 class="dashboard-title">Reviews</h2>

  <nav class="owner-nav" aria-label="Owner navigation">
    <a href="/owner/dashboard">Dashboard</a>
    <a href="/owner/my-pgs">My PGs</a>
    <a href="/owner/add-pg">Add New PG</a>
    <a href="/owner/enquiries">Student Requests</a>
    <a class="is-active" href="/owner/reviews">Reviews</a>
    <a href="/chat">Chat</a>
  </nav>

  <% if (reviews && reviews.length > 0) { %>
    <% reviews.forEach(r => { %>
      <div class="card mb-3 owner-card">
        <div class="card-body">
          <% if (r.pg) { %>
            <h4><%= r.pg.title %></h4>
            <p><%= r.pg.location %></p>
          <% } %>
          <strong><%= r.user.name %></strong>
          <p>Rating: ⭐ <%= r.rating %> / 5</p>
          <p>Cleanliness: <%= r.cleanliness %></p>
          <p>Food Quality: <%= r.foodQuality %></p>
          <p>Safety: <%= r.safety %></p>
          <p><%= r.comment %></p>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <p class="empty-state">No reviews yet.</p>
  <% } %>
</section>