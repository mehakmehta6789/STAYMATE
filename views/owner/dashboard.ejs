<% pageCSS = 'owner-dashboard.css' %>

<section class="container dashboard-page mt-4">
  <h2 class="dashboard-title">Dashboard for Admin</h2>

  <nav class="owner-nav" aria-label="Owner navigation">
    <a class="is-active" href="/owner/dashboard">Dashboard</a>
    <a href="/owner/my-pgs">My PGs</a>
    <a href="/owner/add-pg">Add New PG</a>
    <a href="/owner/enquiries">Student Requests</a>
    <a href="/owner/reviews">Reviews</a>
    <a href="/chat">Chat</a>
  </nav>

  <div class="dashboard-board">
    <aside class="dash-sidebar">
      <div class="dash-brand">Owner Panel</div>
      <a class="dash-link is-active" href="/owner/dashboard">Dashboard</a>
      <a class="dash-link" href="/owner/my-pgs">My PGs</a>
      <a class="dash-link" href="/owner/add-pg">Add New PG</a>
      <a class="dash-link" href="/owner/enquiries">Student Requests</a>
      <a class="dash-link" href="/owner/reviews">Reviews</a>
      <a class="dash-link" href="/chat">Chat</a>
      <a class="dash-link" href="/owner/profile">Profile</a>
    </aside>

    <div class="dash-main">
      <div class="hero-panel card-panel">
        <div>
          <h3>Welcome, Owner!</h3>
          <p>Track your listings, requests, and feedback in one organized admin space.</p>
        </div>
        <div class="hero-avatar-wrap">
          <% if (account?.profileImage) { %>
            <img class="hero-avatar" src="<%= account.profileImage %>" alt="Owner avatar" />
          <% } else { %>
            <div class="hero-avatar-fallback"><%= (account?.name || 'O').charAt(0).toUpperCase() %></div>
          <% } %>
        </div>
        <span class="profile-chip ok">Total PGs: <%= pgs ? pgs.length : 0 %></span>
      </div>

      <div class="dashboard-stats">
        <article class="card-panel stat">
          <h4>Total PGs</h4>
          <p>Manage your existing PG inventory and keep listings updated.</p>
          <a href="/owner/my-pgs" class="btn btn-secondary">View PGs</a>
        </article>

        <article class="card-panel stat">
          <h4>Add New PG</h4>
          <p>Publish a new PG with amenities, rent details, and photos.</p>
          <a href="/owner/add-pg" class="btn btn-primary">Add PG</a>
        </article>

        <article class="card-panel stat">
          <h4>Enquiries</h4>
          <p>Review incoming student interest and respond quickly.</p>
          <a href="/owner/enquiries" class="btn btn-secondary">View Enquiries</a>
        </article>

        <article class="card-panel stat">
          <h4>Reviews</h4>
          <p>Check ratings and feedback to improve listing quality.</p>
          <a href="/owner/reviews" class="btn btn-secondary">View Reviews</a>
        </article>
      </div>
    </div>
  </div>
</section>